# ============================================
# Honda WhatsApp Bot - Environment Variables
# ============================================

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017/honda_booking_bot
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/honda_booking_bot

# ---- WhatsApp Cloud API (Meta) ----
# Get these from: https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_custom_verify_token_string
WHATSAPP_API_VERSION=v19.0

# ---- Groq API ----
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# ---- Admin API ----
ADMIN_SECRET_KEY=your_strong_admin_secret_key

# ---- App Config ----
MAX_BOOKING_DAYS_AHEAD=7
SLOT_CAPACITY=3
DEALERSHIP_NAME=Honda World
